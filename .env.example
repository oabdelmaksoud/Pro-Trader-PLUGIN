# CooperCorp PRJ-002 — Environment Variables Template
# Copy this to .env and fill in your values
# NEVER commit .env to git

# Alpaca Paper Trading (get from alpaca.markets)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# For live trading (switch when ready — requires HITL approval)
# ALPACA_BASE_URL=https://api.alpaca.markets

# Anthropic (for LangGraph full pipeline via run_live.py / analyze.py)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Alpha Vantage — FREE tier gives 25 req/day of Bloomberg/Reuters news sentiment
# Get free key at: https://www.alphavantage.co/support/#api-key
# With key: news_analyst and social_media_analyst get real Bloomberg/Reuters data
# Without key: falls back to yfinance news (still good, just less premium)
ALPHA_VANTAGE_KEY=your_key_hereyour_alpha_vantage_key_here

# Optional: OpenAI (if using openai provider)
# OPENAI_API_KEY=your_openai_api_key_here

# Finnhub — FREE tier: 60 req/min, Bloomberg/Reuters news + earnings + sentiment
# Get free key at: https://finnhub.io (30 seconds to register)
FINNHUB_API_KEY=your_finnhub_key_here

# Reddit — FREE: retail sentiment from r/wallstreetbets, r/stocks, r/investing
# Create app at: https://www.reddit.com/prefs/apps (select "script")
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=CooperCorpTrading/1.0

# Stocktwits — NO KEY NEEDED: public API, retail trader sentiment
# Automatically used, no configuration required
